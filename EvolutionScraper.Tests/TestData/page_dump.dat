<script type="text/javascript">
function autoSubmitDateTo(dayWeekOrMonth, addOrSub) {
	
    var tmpDate;

	if (dayWeekOrMonth == true && dayWeekOrMonth != "month" ) {
		if (addOrSub)	{
			tmpDate = "28/03/2026";
		} else {
			tmpDate = "26/03/2026";
		}
	} else if (dayWeekOrMonth == false || dayWeekOrMonth == "week") {
		if (addOrSub)	{
			tmpDate = "03/04/2026";
		} else {
			tmpDate = "20/03/2026";
		}
	} else { //month
		if (addOrSub)	{
			tmpDate = "27/04/2026";
		} else {
			tmpDate = "27/02/2026";
		}
	}
	document.search2.txtDate.value = tmpDate;
	document.search2.pageNum.value = 1;
	document.search2.submit();
}
function autoSubmitToToday() {
	document.search2.txtDate.value = "27/03/2026";
	document.search2.pageNum.value = 1;
	document.search2.submit();
}
</script>

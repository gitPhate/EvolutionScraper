<script type="text/javascript">
    $(function () {
        
            window.scrollToDay = function () {
                // anchor to the date
                if ($('#an6').offset() != null) {
                    if (window.implementationSwitchIsEnabled('AB_1220668_Class_Schedule_Responsive') && window.outerWidth <= 768) {
                        var scrollValue = $('#an6').offset().top - 10;
                    } else {
                        var scrollValue = $('#an6').offset().top - $('#classSchedule-header').offset().top - 20;
                    }
                    
                        $(document).scrollTop(scrollValue);
                        
                }
            }
            window.scrollToDay();
            
    });
</script>






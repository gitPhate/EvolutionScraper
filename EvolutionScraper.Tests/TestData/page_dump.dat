<script type="text/javascript">
    // Emit the AB tests right here.
    //Parse ABTests from the session into an array
    var abTests = ",5,6,7,8,1001,1004,1006,1008,1009,1011,1012,1013,1015,1016,1017,1024,1025,1026,1027,1029,1030,1032,1033,1035,1038,1039,1040,1044,1048,1052,1054,1055,".split(',');
	window.ABTests = {};
	
	//Put the array of AB tests into a dictionary object
	for(var i=0; i<abTests.length ; i++)
	{
		var item = abTests[i];
		if(item!='' && item != ' ' && item != null)
			window.ABTests[item] = true;
	}
	
	function ABTestIsEnabled(abtest){
		//Make sure 'abtest' is an integer
		if(typeof abtest != 'number' || abtest % 1 != 0)
			return false;
		//Check if 'abtest' exists in the ABTest dictionary object
		if(window.ABTests[abtest])
			return true;
		return false;
	}
</script>



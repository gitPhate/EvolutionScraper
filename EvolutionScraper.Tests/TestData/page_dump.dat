<script type="text/javascript">
    document.addEventListener('DOMContentLoaded', () => {
        loginFocus();
	    makeContentScrollable(true, false, false);
	    $(window).bind('GlobalMakeContentScrollable', function() {
	        makeContentScrollable(true, false, false);
	    });
        $(window).bind('resize', triggerMakeContentScrollable);

        setTimeout(() => {
            // There is a bug that the height is calculated wrong sometimes
            // but when we call the function ms later it already works
            // So I am setting a timeout to be sure that the footer always appears
            const wrapper = $('#wrapper-frame');

            const fixedHeight = $('#fixedTop').outerHeight() + $('#fixed-bar').outerHeight();
            const windowHeight = $(window).height();

            const wrapperHeight = wrapper.height();

            if (windowHeight - fixedHeight !== wrapperHeight) {
                makeContentScrollable(true, false, false);
            }
        }, 1000)
    })
</script>


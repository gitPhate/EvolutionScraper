<script type="text/javascript" src="https://static.mindbodyonline.com/a/scripts/mb_3448370109.js"></script><script type="text/javascript" src="https://static.mindbodyonline.com/a/scripts/hotwords_1027325630.js"></script>
<script type="text/javascript">
    const getTokens = async () => {
        try {
            const response = await fetch("/authentication/GetTokens", {
                method: "GET",
                headers: {
                    'Content-Type': 'application/json'
                }
            });
            const jsonResult = await response.json();
            return jsonResult;
        } catch (error) {
            console.error(error);
            return null;
        }
    };

    (async () => {
        tokens = await getTokens();
        window.UserToken = tokens.userToken;
        window.IdentityAccessToken = tokens.identityToken;        
        window.sessionStorage.UserToken = tokens.userToken;
        if(!isIdentityFeatureFlagEnabled("Remove-User-Refresh-Token-In-FE")) {
            window.UserRefreshToken = "";
            window.sessionStorage.UserRefreshToken = "";
        }
        if (isFeatureEnabled(NavigationRedesign, FitnessFeatureFlagPolicy, true)) {
            window.parent.UserToken = tokens.userToken;
            window.parent.IdentityAccessToken = tokens.identityToken;
            if (!isIdentityFeatureFlagEnabled("Remove-User-Refresh-Token-In-FE")) {
                window.parent.UserRefreshToken = "";
            }
        }
    })();
    
    // Add local storage item to prevent a first time user lightbox.
    var subscriberId = '531524';
    var userId = '100036735';
    var cacheValue =  {
        'value': `{\"dismissableCache\":[[\"${userId}_FTUDialog\",true]]}`,
        'cacheExpire': null
    }
    window.localStorage.setItem(`mb/subscriber/${subscriberId}/UserDismissableSettings`, JSON.stringify(cacheValue));

    window.localStorage.setItem("IsLeadManagementEnabled", 'False');

    
	window.UserTokenExpiration = '2026-03-28T00:58:12.9498748-07:00';
	window.RestAPIUrl = 'https://api.mindbodyonline.com';
	window.ConnectAPIUrl = 'https://connect.mindbodyonline.com';
	window.SubscribersAPIUrl = 'https://subscriber.mindbodyonline.com';
    window.PaymentsAPIUrl = 'https://payments.mindbodyonline.com';
    window.BusinessesUrl = 'https://www.mindbodyapis.com/businesses';
    window.SalesUrl = 'https://www.mindbodyapis.com/sales';
    window.StaffManagementUrl = 'https://www.mindbodyapis.com/staffmanagement';
    window.SchedulingDomainAPIUrl = 'https://www.mindbodyapis.com/scheduling';
    window.GraphqlUrl = 'https://graphql.mindbodyapis.com/';
    window.TimeZoneOffsetMinGMT = 0;
    window.sessionStorage.UserTokenExpiration = '2026-03-28T00:58:12.9498748-07:00';

    if (isFeatureEnabled(NavigationRedesign, FitnessFeatureFlagPolicy, true)) {
        window.parent.UserTokenExpiration = '2026-03-28T00:58:12.9498748-07:00';
        window.parent.RestAPIUrl = 'https://api.mindbodyonline.com';
        window.parent.ConnectAPIUrl = 'https://connect.mindbodyonline.com';
        window.parent.SubscribersAPIUrl = 'https://subscriber.mindbodyonline.com';
        window.parent.PaymentsAPIUrl = 'https://payments.mindbodyonline.com';
        window.parent.SchedulingDomainAPIUrl = 'https://www.mindbodyapis.com/scheduling';
        window.parent.TimeZoneOffsetMinGMT = 0;
    }

	var sign = window.TimeZoneOffsetMinGMT < 0 ? "-" : "+";
	var hours = Math.floor(Math.abs(window.TimeZoneOffsetMinGMT / 60)); // full hours
	var minutes = ((Math.abs(window.TimeZoneOffsetMinGMT / 60)) % 1) * 60; // Minutes
	window.TimeZoneString = sign;
	if (hours < 10) {
		window.TimeZoneString += "0" + hours.toFixed(0);
	} else {
		window.TimeZoneString  += hours.toFixed(0);
	}
	if (minutes == 0) {
		window.TimeZoneString += "00";
	}
	else {
		// There is a bug here if you actually have a < 10 minute timezone offset.
		// Hopefully that is only a thing from my waking nightmares....
		window.TimeZoneString += minutes.toFixed(0);
	}
</script>


